rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Rate limit documents — server-side only, no client access
    match /_rateLimits/{doc} {
      allow read, write: if false;
    }

    // IP rate limit documents — server-side only, no client access
    match /_ipRateLimits/{doc} {
      allow read, write: if false;
    }

    // Webhook idempotency records — server-side only (Decision 32)
    // Written by stripeWebhook Cloud Function to prevent duplicate processing
    match /_webhookEvents/{eventId} {
      allow read, write: if false;
    }
    
    // User-scoped data
    match /users/{userId} {
      // Only authenticated users can access their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Subscription data (read-only for client; writes via Cloud Functions)
      match /subscription/{subId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only server-side writes via Cloud Functions
      }
      
      // Workspaces subcollection
      // Cross-workspace writes supported for same user (e.g., Share node to another workspace)
      match /workspaces/{workspaceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        // Nodes within workspace — defense-in-depth: validate denormalized userId
        match /nodes/{nodeId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow write: if request.auth != null && request.auth.uid == userId
                          && (resource == null || !resource.data.userId || resource.data.userId == request.auth.uid);
        }
        
        // Edges within workspace — defense-in-depth: validate denormalized userId
        match /edges/{edgeId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow write: if request.auth != null && request.auth.uid == userId
                          && (resource == null || !resource.data.userId || resource.data.userId == request.auth.uid);
        }

        // Spatial tile subcollections — nodes grouped by canvas region
        match /tiles/{tileId}/nodes/{nodeId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow write: if request.auth != null && request.auth.uid == userId
                          && (resource == null || !resource.data.userId || resource.data.userId == request.auth.uid);
        }

        // Knowledge Bank entries within workspace
        match /knowledgeBank/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Google Calendar OAuth integration — refresh tokens are server-only;
      // only the owning user may read/write their own integration document.
      match /integrations/{integrationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Usage tracking — tier limit counters
      // aiDaily: server-write only (Cloud Function increments) — client can read for optimistic UI
      // storage: client read+write allowed for tracking (fire-and-forget safe, no sensitive data)
      match /usage/aiDaily {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Cloud Functions only (admin SDK bypasses rules)
      }
      match /usage/storage {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
  }
}
