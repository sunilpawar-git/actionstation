rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shared canvas snapshots — public read, authenticated write with 5 MB cap
    match /shared-snapshots/{snapshotId} {
      allow read: if true;
      allow write: if request.auth != null
                      && request.resource.size < 5 * 1024 * 1024;
    }

    // Node images — 5 MB cap, any authenticated owner
    match /users/{userId}/workspaces/{workspaceId}/nodes/{nodeId}/images/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.size < 5 * 1024 * 1024;
    }

    // Document attachments — 15 MB cap + content-type enforcement
    match /users/{userId}/workspaces/{workspaceId}/nodes/{nodeId}/attachments/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.size < 15 * 1024 * 1024
                      && request.resource.contentType.matches('application/pdf|text/plain|text/csv|text/markdown|image/png');
    }

    // Catch-all for other user paths (KB, profile, etc.) — 5 MB
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
